# ── Meridian environment template ─────────────────────────────────────────────
# Copy to .env.local and fill in. The frontend runs fully on mock data with ZERO
# keys set (NEXT_PUBLIC_AGENT_MODE=mock is the default). Person A: fill in the
# ClickHouse/Postgres/LLM sections when the pipeline goes live.

# Frontend mode: 'mock' (built-in demo stream) | 'live' (proxy to Trigger.dev agent)
NEXT_PUBLIC_AGENT_MODE=mock

# ── Trigger.dev ───────────────────────────────────────────────────────────────
# From https://cloud.trigger.dev → project settings
TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxx
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxx

# ── ClickHouse Cloud (primary analytical DB) ──────────────────────────────────
CLICKHOUSE_URL=https://xxxxxxxx.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=meridian

# ── Postgres (OLTP: accounts, deals, themes taxonomy) ─────────────────────────
POSTGRES_URL=postgres://user:password@host:5432/meridian

# ── LLM: Azure OpenAI (PRIMARY for live agent / chat.agent synthesis) ─────────
# Required for NEXT_PUBLIC_AGENT_MODE=live general questions via Trigger chat.agent().
# Values go in .env.local / Vercel / Trigger — never commit real keys.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
# Optional alias if you prefer resource name over full endpoint:
# AZURE_OPENAI_RESOURCE_NAME=your-resource

# Agent model selection (defaults to Azure when AZURE_OPENAI_* is set):
#   AGENT_PROVIDER=azure|anthropic
#   AGENT_MODEL=…                 (Anthropic model id, or overrides deployment name)
#   AGENT_MAX_OUTPUT_TOKENS=1024  (maps to max_completion_tokens for gpt-5.*)

# ── LLM: bulk generation / extraction (optional; seed + extract pipelines) ───
# Seed generation historically used Anthropic/Gemini/Groq. Extraction defaults
# to Anthropic Haiku; set EXTRACT_PROVIDER=azure to prefer Azure for new runs.
# GOOGLE_GENERATIVE_AI_API_KEY=AIza-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxx
# GROQ_API_KEY=
#
# Generation tuning (optional):
#   GEN_PROVIDER=anthropic|google|openai|xai|groq|cerebras
#   GEN_MODEL=…
#   GEN_CONCURRENCY=2
#   GEN_MIN_INTERVAL_MS=4200
# Extraction:
#   EXTRACT_PROVIDER=anthropic|google|openai|groq|azure
#   EXTRACT_MODEL=…
