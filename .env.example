# ── Meridian environment template ─────────────────────────────────────────────
# Copy to .env.local and fill in. The frontend runs fully on mock data with ZERO
# keys set (NEXT_PUBLIC_AGENT_MODE=mock is the default). Person A: fill in the
# ClickHouse/Postgres/LLM sections when the pipeline goes live.

# Frontend mode: 'mock' (built-in demo stream) | 'live' (proxy to Trigger.dev agent)
NEXT_PUBLIC_AGENT_MODE=mock

# ── Trigger.dev ───────────────────────────────────────────────────────────────
# From https://cloud.trigger.dev → project settings
TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxx
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxx

# ── ClickHouse Cloud (primary analytical DB) ──────────────────────────────────
CLICKHOUSE_URL=https://xxxxxxxx.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=meridian

# ── Postgres (OLTP: accounts, deals, themes taxonomy) ─────────────────────────
POSTGRES_URL=postgres://user:password@host:5432/meridian

# ── LLM keys (agent synthesis + bulk extraction) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
